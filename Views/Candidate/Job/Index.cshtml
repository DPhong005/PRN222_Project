@model DevHub.ViewModels.Jobs.JobSearchPageViewModel
@{
    ViewData["Title"] = "Tìm Việc Làm";
    bool isAuthenticated = User.Identity?.IsAuthenticated == true;
}

<!-- Top Header Section -->
<section class="py-12 border-b border-bordercolor relative overflow-hidden" style="background-color: #F7F5FC;">
    <!-- SVG Background Pattern -->
    <div class="absolute top-0 right-0 w-1/2 h-full opacity-70 pointer-events-none" aria-hidden="true">
        <svg viewBox="0 0 500 300" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
            <path d="M450 -50 Q300 100 200 200 Q100 300 -50 250" stroke="#C4C4E6" stroke-width="1.5"/>
            <path d="M500 50 Q350 150 250 250 Q150 350 0 300" stroke="#C4C4E6" stroke-width="1.5"/>
            <path d="M480 0 Q320 120 220 220" stroke="#C4C4E6" stroke-width="1"/>
        </svg>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <!-- Breadcrumb -->
        <div class="text-sm text-muted mb-4 flex items-center space-x-2">
            <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            <a href="/" class="hover:text-primary transition-colors">Trang chủ</a>
            <span>&rsaquo;</span>
            <span class="text-dark font-medium">Việc làm</span>
        </div>

        <!-- Title -->
        <h1 class="text-[32px] md:text-[40px] font-bold text-dark mb-8">
            @if (Model.Filter.TechId.HasValue)
            {
                var activeTech = Model.TopTechs.FirstOrDefault(t => t.TechId == Model.Filter.TechId.Value);
                <span>Việc làm <span class="text-primary">@(activeTech.TechName ?? "Kỹ năng")</span></span>
            }
            else if (!string.IsNullOrWhiteSpace(Model.Filter.FilterLocation))
            {
                <span>Việc làm tại <span class="text-primary">@Model.Filter.FilterLocation</span></span>
            }
            else if (Model.Filter.RecruiterId.HasValue)
            {
                var activeCompany = Model.TopCompanies.FirstOrDefault(c => c.RecruiterId == Model.Filter.RecruiterId.Value);
                <span>Việc làm tại <span class="text-primary">@(activeCompany.CompanyName ?? "Công ty")</span></span>
            }
            else if (!string.IsNullOrWhiteSpace(Model.Filter.Keyword))
            {
                <span>Kết quả cho "<span class="text-primary">@Model.Filter.Keyword</span>"</span>
            }
            else
            {
                <span>Tất cả các <span class="text-primary">việc làm</span></span>
            }
            <span class="text-muted text-[18px] font-normal ml-2">(@Model.TotalCount việc làm)</span>
        </h1>

        <!-- Search Bar -->
        <form method="get" action="/Jobs" id="jobs-search-form">
            <input type="hidden" name="workingModel" value="@Model.Filter.WorkingModel" />
            <input type="hidden" name="experienceLevel" value="@Model.Filter.ExperienceLevel" />
            @if (Model.Filter.MinSalary.HasValue) { <input type="hidden" name="minSalary" value="@Model.Filter.MinSalary" /> }
            @if (Model.Filter.MaxSalary.HasValue) { <input type="hidden" name="maxSalary" value="@Model.Filter.MaxSalary" /> }
            @if (Model.Filter.TechId.HasValue) { <input type="hidden" name="techId" value="@Model.Filter.TechId" /> }
            @if (!string.IsNullOrWhiteSpace(Model.Filter.FilterLocation)) { <input type="hidden" name="filterLocation" value="@Model.Filter.FilterLocation" /> }
            @if (Model.Filter.RecruiterId.HasValue) { <input type="hidden" name="recruiterId" value="@Model.Filter.RecruiterId" /> }
            <input type="hidden" name="page" value="1" />

            <div class="bg-white p-3 shadow-[0_15px_40px_-10px_rgba(70,64,222,0.15)] md:rounded-full rounded-3xl flex flex-col md:flex-row items-center border border-purple-100">
                <div class="flex items-center flex-1 w-full px-4 py-2 border-b md:border-b-0 md:border-r border-bordercolor mb-2 md:mb-0">
                    <svg class="w-5 h-5 text-gray-400 mr-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                    <input id="jobs-keyword"
                           name="keyword"
                           type="text"
                           value="@Model.Filter.Keyword"
                           placeholder="Tên công việc hoặc kỹ năng"
                           class="w-full focus:outline-none text-dark placeholder-gray-400 truncate" />
                </div>
                <button id="jobs-search-btn"
                        type="submit"
                        class="w-full md:w-auto bg-primary text-white font-bold py-3.5 px-8 md:rounded-full rounded-[20px] hover:bg-opacity-90 transition-all whitespace-nowrap text-[16px] flex-shrink-0 shadow-md">
                    Tìm kiếm việc làm
                </button>
            </div>
        </form>
    </div>
</section>

<!-- Quick-Filter Tab Section -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-0">
    <div class="flex flex-wrap gap-3">
        @{
            bool techActive    = Model.Filter.TechId.HasValue;
            bool cityActive    = !string.IsNullOrWhiteSpace(Model.Filter.FilterLocation);
            bool companyActive = Model.Filter.RecruiterId.HasValue;
        }

        <!-- Nút: Việc làm theo Kỹ năng -->
        <div class="relative quick-filter-wrapper">
            <button type="button"
                    onclick="togglePanel('tech-panel')"
                    class="flex items-center gap-2 px-4 py-2.5 rounded-full border font-semibold text-[14px] transition-all
                           @(techActive ? "bg-primary text-white border-primary" : "bg-white text-dark border-bordercolor hover:border-primary hover:text-primary")">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                Việc làm theo Kỹ năng
                @if (techActive) { <span class="w-2 h-2 rounded-full bg-white opacity-80"></span> }
                <svg class="w-3.5 h-3.5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>

            <!-- Panel kỹ năng -->
            <div id="tech-panel" class="hidden absolute left-0 top-full mt-2 bg-white border border-bordercolor rounded-2xl shadow-xl p-4 z-50 w-[520px] max-h-72 overflow-y-auto">
                @if (techActive)
                {
                    <a href="@Url.Action("Index", "Jobs", new { keyword = Model.Filter.Keyword, workingModel = Model.Filter.WorkingModel, experienceLevel = Model.Filter.ExperienceLevel, minSalary = Model.Filter.MinSalary, maxSalary = Model.Filter.MaxSalary })"
                       class="inline-flex items-center gap-1 text-primary text-[13px] hover:underline mb-3 font-medium">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                        Xóa lọc kỹ năng
                    </a>
                }
                <div class="flex flex-wrap gap-2">
                    @foreach (var tech in Model.TopTechs)
                    {
                        <a href="@Url.Action("Index", "Jobs", new { keyword = Model.Filter.Keyword, workingModel = Model.Filter.WorkingModel, experienceLevel = Model.Filter.ExperienceLevel, minSalary = Model.Filter.MinSalary, maxSalary = Model.Filter.MaxSalary, techId = tech.TechId, page = 1 })"
                           class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border text-[13px] font-medium transition-all
                                  @(Model.Filter.TechId == tech.TechId ? "bg-primary text-white border-primary" : "border-gray-200 text-dark hover:border-primary hover:text-primary")">
                            @tech.TechName
                            <span class="text-[11px] @(Model.Filter.TechId == tech.TechId ? "opacity-80" : "text-muted")">@tech.JobCount</span>
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Nút: Việc làm theo Thành phố -->
        <div class="relative quick-filter-wrapper">
            <button type="button"
                    onclick="togglePanel('filter-city-panel')"
                    class="flex items-center gap-2 px-4 py-2.5 rounded-full border font-semibold text-[14px] transition-all
                           @(cityActive ? "bg-primary text-white border-primary" : "bg-white text-dark border-bordercolor hover:border-primary hover:text-primary")">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                Việc làm theo Thành phố
                @if (cityActive) { <span class="w-2 h-2 rounded-full bg-white opacity-80"></span> }
                <svg class="w-3.5 h-3.5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>

            <!-- Panel thành phố -->
            <div id="filter-city-panel" class="hidden absolute left-0 top-full mt-2 bg-white border border-bordercolor rounded-2xl shadow-xl p-4 z-50 w-72 max-h-72 overflow-y-auto">
                @if (cityActive)
                {
                    <a href="@Url.Action("Index", "Jobs", new { keyword = Model.Filter.Keyword, workingModel = Model.Filter.WorkingModel, experienceLevel = Model.Filter.ExperienceLevel, minSalary = Model.Filter.MinSalary, maxSalary = Model.Filter.MaxSalary, techId = Model.Filter.TechId })"
                       class="inline-flex items-center gap-1 text-primary text-[13px] hover:underline mb-3 font-medium">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                        Xóa lọc thành phố
                    </a>
                }
                <div class="space-y-1">
                    @foreach (var loc in Model.TopLocations)
                    {
                        <a href="@Url.Action("Index", "Jobs", new { keyword = Model.Filter.Keyword, workingModel = Model.Filter.WorkingModel, experienceLevel = Model.Filter.ExperienceLevel, minSalary = Model.Filter.MinSalary, maxSalary = Model.Filter.MaxSalary, techId = Model.Filter.TechId, filterLocation = loc.Location, page = 1 })"
                           class="flex justify-between items-center px-3 py-2 rounded-lg text-[14px] transition-colors
                                  @(Model.Filter.FilterLocation == loc.Location ? "bg-primary/10 text-primary font-semibold" : "text-dark hover:bg-gray-50 hover:text-primary")">
                            <span>@loc.Location</span>
                            <span class="text-[12px] text-muted ml-2">@loc.JobCount việc</span>
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Nút: Việc làm theo Công ty -->
        <div class="relative quick-filter-wrapper">
            <button type="button"
                    onclick="togglePanel('filter-company-panel')"
                    class="flex items-center gap-2 px-4 py-2.5 rounded-full border font-semibold text-[14px] transition-all
                           @(companyActive ? "bg-primary text-white border-primary" : "bg-white text-dark border-bordercolor hover:border-primary hover:text-primary")">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                Việc làm theo Công ty
                @if (companyActive) { <span class="w-2 h-2 rounded-full bg-white opacity-80"></span> }
                <svg class="w-3.5 h-3.5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>

            <!-- Panel công ty -->
            <div id="filter-company-panel" class="hidden absolute left-0 top-full mt-2 bg-white border border-bordercolor rounded-2xl shadow-xl p-4 z-50 w-80 max-h-72 overflow-y-auto">
                @if (companyActive)
                {
                    <a href="@Url.Action("Index", "Jobs", new { keyword = Model.Filter.Keyword, workingModel = Model.Filter.WorkingModel, experienceLevel = Model.Filter.ExperienceLevel, minSalary = Model.Filter.MinSalary, maxSalary = Model.Filter.MaxSalary, techId = Model.Filter.TechId, filterLocation = Model.Filter.FilterLocation })"
                       class="inline-flex items-center gap-1 text-primary text-[13px] hover:underline mb-3 font-medium">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                        Xóa lọc công ty
                    </a>
                }
                <div class="space-y-1">
                    @foreach (var company in Model.TopCompanies)
                    {
                        <a href="@Url.Action("Index", "Jobs", new { keyword = Model.Filter.Keyword, workingModel = Model.Filter.WorkingModel, experienceLevel = Model.Filter.ExperienceLevel, minSalary = Model.Filter.MinSalary, maxSalary = Model.Filter.MaxSalary, techId = Model.Filter.TechId, filterLocation = Model.Filter.FilterLocation, recruiterId = company.RecruiterId, page = 1 })"
                           class="flex justify-between items-center px-3 py-2 rounded-lg text-[14px] transition-colors
                                  @(Model.Filter.RecruiterId == company.RecruiterId ? "bg-primary/10 text-primary font-semibold" : "text-dark hover:bg-gray-50 hover:text-primary")">
                            <div class="flex items-center gap-2 min-w-0">
                                @if (!string.IsNullOrEmpty(company.LogoUrl))
                                {
                                    <img src="@company.LogoUrl" class="w-6 h-6 rounded object-contain flex-shrink-0" />
                                }
                                else
                                {
                                    <span class="w-6 h-6 rounded bg-primary/10 flex items-center justify-center text-primary font-bold text-[11px] flex-shrink-0">@company.CompanyName[0]</span>
                                }
                                <span class="truncate">@company.CompanyName</span>
                            </div>
                            <span class="text-[12px] text-muted ml-2 flex-shrink-0">@company.JobCount việc</span>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex flex-col md:flex-row gap-8">

    <!-- Sidebar Filters -->
    <aside class="w-full md:w-1/4 border border-bordercolor shadow-[0_8px_30px_rgb(0,0,0,0.08)] rounded-2xl p-6 bg-white h-fit">
        <form method="get" action="/Jobs" id="filter-form">
            <!-- Giữ keyword + quick-filter params khi dùng sidebar -->
            <input type="hidden" name="keyword" value="@Model.Filter.Keyword" />
            @if (Model.Filter.TechId.HasValue) { <input type="hidden" name="techId" value="@Model.Filter.TechId" /> }
            @if (!string.IsNullOrWhiteSpace(Model.Filter.FilterLocation)) { <input type="hidden" name="filterLocation" value="@Model.Filter.FilterLocation" /> }
            @if (Model.Filter.RecruiterId.HasValue) { <input type="hidden" name="recruiterId" value="@Model.Filter.RecruiterId" /> }
            <input type="hidden" name="page" value="1" />

            <!-- Filter: Hình thức làm việc (load từ DB) -->
            @if (Model.WorkingModelOptions.Any())
            {
                <div class="mb-5 border-b border-gray-100 pb-5">
                    <div class="flex justify-between items-center mb-3 cursor-pointer select-none filter-header">
                        <h3 class="font-bold text-dark text-[15px]">Hình thức làm việc</h3>
                        <svg class="w-4 h-4 text-dark transition-transform duration-300 filter-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                        </svg>
                    </div>
                    <div class="space-y-2.5 filter-content">
                        @foreach (var wm in Model.WorkingModelOptions)
                        {
                            <label class="flex items-center space-x-3 cursor-pointer group">
                                <input type="radio"
                                       name="workingModel"
                                       value="@wm"
                                       class="form-radio h-4 w-4 text-primary border-gray-300 focus:ring-primary"
                                       @(Model.Filter.WorkingModel == wm ? "checked" : "")
                                       onchange="document.getElementById('filter-form').submit()" />
                                <span class="text-muted text-[14px] group-hover:text-dark transition-colors">@wm</span>
                            </label>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.Filter.WorkingModel))
                        {
                            <a href="@Url.Action("Index", "Jobs", new { keyword = Model.Filter.Keyword, experienceLevel = Model.Filter.ExperienceLevel, minSalary = Model.Filter.MinSalary, maxSalary = Model.Filter.MaxSalary })"
                               class="text-primary text-[13px] hover:underline block">Xóa lọc</a>
                        }
                    </div>
                </div>
            }

            <!-- Filter: Cấp độ kinh nghiệm (load từ DB) -->
            @if (Model.ExperienceLevelOptions.Any())
            {
                <div class="mb-5 border-b border-gray-100 pb-5">
                    <div class="flex justify-between items-center mb-3 cursor-pointer select-none filter-header">
                        <h3 class="font-bold text-dark text-[15px]">Cấp độ kinh nghiệm</h3>
                        <svg class="w-4 h-4 text-dark transition-transform duration-300 filter-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                        </svg>
                    </div>
                    <div class="space-y-2.5 filter-content">
                        @foreach (var level in Model.ExperienceLevelOptions)
                        {
                            <label class="flex items-center space-x-3 cursor-pointer group">
                                <input type="radio"
                                       name="experienceLevel"
                                       value="@level"
                                       class="form-radio h-4 w-4 text-primary border-gray-300 focus:ring-primary"
                                       @(Model.Filter.ExperienceLevel == level ? "checked" : "")
                                       onchange="document.getElementById('filter-form').submit()" />
                                <span class="text-muted text-[14px] group-hover:text-dark transition-colors">@level</span>
                            </label>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.Filter.ExperienceLevel))
                        {
                            <a href="@Url.Action("Index", "Jobs", new { keyword = Model.Filter.Keyword, workingModel = Model.Filter.WorkingModel, minSalary = Model.Filter.MinSalary, maxSalary = Model.Filter.MaxSalary })"
                               class="text-primary text-[13px] hover:underline block">Xóa lọc</a>
                        }
                    </div>
                </div>
            }

            <!-- Filter: Khoảng lương mong muốn (Dual Range Slider) -->
            <div class="mb-5">
                <div class="flex justify-between items-center mb-3 cursor-pointer select-none filter-header">
                    <h3 class="font-bold text-dark text-[15px]">Khoảng lương mong muốn</h3>
                    <svg class="w-4 h-4 text-dark transition-transform duration-300 filter-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                    </svg>
                </div>
                <div class="space-y-3 filter-content">
                    <input type="hidden" name="minSalary" id="hidden-min-salary" value="@Model.Filter.MinSalary" />
                    <input type="hidden" name="maxSalary" id="hidden-max-salary" value="@Model.Filter.MaxSalary" />

                    <!-- Ô nhập số trực tiếp song song -->
                    <div class="flex items-center gap-2">
                        <div class="flex-1">
                            <label class="text-[11px] text-muted block mb-1 font-medium">Tối thiểu (VNĐ)</label>
                            <input type="text" id="display-min-salary" placeholder="0"
                                   class="w-full border border-gray-300 rounded-lg px-2.5 py-1.5 text-[13px] text-dark focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary" />
                        </div>
                        <span class="text-muted font-bold self-end pb-1.5">-</span>
                        <div class="flex-1">
                            <label class="text-[11px] text-muted block mb-1 font-medium">Tối đa (VNĐ)</label>
                            <input type="text" id="display-max-salary" placeholder="100.000.000"
                                   class="w-full border border-gray-300 rounded-lg px-2.5 py-1.5 text-[13px] text-dark focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary" />
                        </div>
                    </div>

                    <!-- Dual Range Slider Container -->
                    <div class="relative w-full h-5 flex items-center my-1 select-none">
                        <div class="w-full h-2 bg-gray-200 rounded-lg absolute pointer-events-none"></div>
                        <div id="slider-track" class="h-2 bg-primary rounded-lg absolute pointer-events-none"></div>
                        
                        <input type="range" id="min-salary-slider" min="0" max="100000000" step="1000000"
                               value="@(Model.Filter.MinSalary ?? 0)"
                               class="range-slider-input w-full absolute appearance-none bg-transparent cursor-pointer z-20" />
                        <input type="range" id="max-salary-slider" min="0" max="100000000" step="1000000"
                               value="@(Model.Filter.MaxSalary ?? 100000000)"
                               class="range-slider-input w-full absolute appearance-none bg-transparent cursor-pointer z-10" />
                    </div>

                    <!-- Quick Presets -->
                    <div class="flex flex-wrap gap-1.5 pt-1">
                        <button type="button" onclick="setSalaryPreset(0, 15000000)" class="text-[11px] px-2 py-1 bg-gray-100 hover:bg-primary/10 hover:text-primary rounded text-muted font-medium transition-colors">&lt; 15 Tr</button>
                        <button type="button" onclick="setSalaryPreset(15000000, 30000000)" class="text-[11px] px-2 py-1 bg-gray-100 hover:bg-primary/10 hover:text-primary rounded text-muted font-medium transition-colors">15 - 30 Tr</button>
                        <button type="button" onclick="setSalaryPreset(30000000, 50000000)" class="text-[11px] px-2 py-1 bg-gray-100 hover:bg-primary/10 hover:text-primary rounded text-muted font-medium transition-colors">30 - 50 Tr</button>
                        <button type="button" onclick="setSalaryPreset(50000000, 100000000)" class="text-[11px] px-2 py-1 bg-gray-100 hover:bg-primary/10 hover:text-primary rounded text-muted font-medium transition-colors">&gt; 50 Tr</button>
                    </div>

                    <button type="submit" class="w-full mt-2 bg-primary text-white font-bold py-2 rounded-lg hover:bg-opacity-90 transition-all text-[13px] shadow-sm">
                        Áp dụng lọc lương
                    </button>
                    @if (Model.Filter.MinSalary.HasValue || Model.Filter.MaxSalary.HasValue)
                    {
                        <a href="@Url.Action("Index", "Jobs", new { keyword = Model.Filter.Keyword, workingModel = Model.Filter.WorkingModel, experienceLevel = Model.Filter.ExperienceLevel, techId = Model.Filter.TechId, filterLocation = Model.Filter.FilterLocation, recruiterId = Model.Filter.RecruiterId })"
                           class="text-primary text-[13px] hover:underline block text-center mt-2 font-medium">Xóa bộ lọc lương</a>
                    }
                </div>
            </div>
        </form>
    </aside>

    <!-- Job List -->
    <div class="w-full md:w-3/4">
        @if (!Model.Jobs.Any())
        {
            <!-- Empty state -->
            <div class="bg-white rounded-[20px] border border-bordercolor p-12 text-center">
                <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <p class="text-muted text-[16px]">Không tìm thấy việc làm phù hợp.</p>
                <a href="/Jobs" class="mt-4 inline-block text-primary hover:underline text-[14px]">Xóa tất cả bộ lọc</a>
            </div>
        }
        else
        {
            <div class="space-y-4">
                @foreach (var job in Model.Jobs)
                {
                    <div class="relative bg-white border border-bordercolor shadow-[0_8px_30px_rgb(0,0,0,0.06)] hover:border-primary hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 rounded-[20px] p-6 group">
                        <!-- Main clickable area spanning the whole card -->
                        <a href="/Jobs/Details/@job.JobId" class="absolute inset-0 z-0 rounded-[20px]" aria-label="@job.Title"></a>

                        <!-- Header: logo + company + deadline -->
                        <div class="flex justify-between items-start mb-3 relative z-10 pointer-events-none">
                            <div class="flex items-center gap-4">
                                <!-- Company Logo -->
                                <div class="w-12 h-12 rounded-full flex items-center justify-center overflow-hidden border border-bordercolor bg-gray-50 flex-shrink-0">
                                    @if (!string.IsNullOrEmpty(job.CompanyLogoUrl))
                                    {
                                        <img src="@job.CompanyLogoUrl" alt="@job.CompanyName" class="w-full h-full object-contain p-1" />
                                    }
                                    else
                                    {
                                        <span class="text-primary font-bold text-[18px]">@(job.CompanyName.Length > 0 ? job.CompanyName[0].ToString().ToUpper() : "?")</span>
                                    }
                                </div>

                                <div>
                                    <h3 class="text-[16px] font-bold text-dark group-hover:text-primary transition-colors">@job.Title</h3>
                                    <div class="flex items-center text-muted text-[13px] mt-1">
                                        <svg class="w-3.5 h-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                        </svg>
                                        @job.CompanyName
                                        @if (!string.IsNullOrEmpty(job.Location))
                                        {
                                            <span class="mx-1">•</span><span>@job.Location</span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <!-- Right Actions -->
                            <div class="flex flex-col items-end gap-2 pointer-events-auto">
                                @if (job.Deadline.HasValue)
                                {
                                    <span class="text-muted text-[12px] bg-gray-50 px-2 py-1 rounded whitespace-nowrap">
                                        Hạn: @job.Deadline.Value.ToString("dd/MM/yyyy")
                                    </span>
                                }
                                <div class="flex items-center gap-2 mt-1" data-is-authenticated="@isAuthenticated.ToString().ToLower()">
                                    @{ bool isBookmarked = Model.BookmarkedJobIds.Contains(job.JobId); }
                                    <button type="button"
                                            class="w-8 h-8 flex items-center justify-center rounded-full transition-colors shadow-sm border bookmark-btn
                                                   @(isBookmarked ? "bg-primary/10 text-primary border-primary/30" : "bg-gray-50 text-gray-400 hover:text-primary hover:bg-primary/10 border-gray-100")"
                                            data-job-id="@job.JobId"
                                            data-bookmarked="@isBookmarked.ToString().ToLower()"
                                            title="@(isBookmarked ? "Bỏ lưu việc làm" : "Lưu việc làm")">
                                        <svg class="w-4 h-4" fill="@(isBookmarked ? "currentColor" : "none")" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
                                        </svg>
                                    </button>
                                    <a href="/Job/Apply/@job.JobId" class="px-3 py-1.5 rounded-full bg-primary/10 text-primary hover:bg-primary hover:text-white transition-all text-[12px] font-semibold border border-primary/20 shadow-sm flex items-center gap-1 group/btn">
                                        Ứng tuyển
                                        <svg class="w-3 h-3 group-hover/btn:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                        </svg>
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- Salary -->
                        @if (job.SalaryMin.HasValue || job.SalaryMax.HasValue)
                        {
                            <div class="flex items-center text-[#4640DE] font-medium text-[14px] mb-3 relative z-10 pointer-events-none">
                                <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                @if (job.SalaryMin.HasValue && job.SalaryMax.HasValue)
                                {
                                    <span>@job.SalaryMin.Value.ToString("N0", new System.Globalization.CultureInfo("vi-VN")) – @job.SalaryMax.Value.ToString("N0", new System.Globalization.CultureInfo("vi-VN")) vnđ</span>
                                }
                                else if (job.SalaryMin.HasValue)
                                {
                                    <span>Từ @job.SalaryMin.Value.ToString("N0", new System.Globalization.CultureInfo("vi-VN")) vnđ</span>
                                }
                                else
                                {
                                    <span>Đến @job.SalaryMax!.Value.ToString("N0", new System.Globalization.CultureInfo("vi-VN")) vnđ</span>
                                }
                            </div>
                        }

                        <!-- Badges: WorkingModel, ExperienceLevel, Tech tags -->
                        <div class="flex flex-wrap gap-2 relative z-10 pointer-events-none">
                            @if (!string.IsNullOrEmpty(job.WorkingModel))
                            {
                                <span class="px-3 py-1 rounded-full border border-green-500 text-green-600 text-[12px] font-medium bg-green-50">@job.WorkingModel</span>
                            }
                            @if (!string.IsNullOrEmpty(job.ExperienceLevel))
                            {
                                <span class="px-3 py-1 rounded-full border border-orange-400 text-orange-500 text-[12px] font-medium bg-orange-50">@job.ExperienceLevel</span>
                            }
                            @foreach (var tech in job.TechNames.Take(3))
                            {
                                <span class="px-3 py-1 rounded-full border border-primary text-primary text-[12px] font-medium bg-primary/5">@tech</span>
                            }
                            @if (job.TechNames.Count > 3)
                            {
                                <span class="px-3 py-1 rounded-full border border-gray-300 text-muted text-[12px]">+@(job.TechNames.Count - 3)</span>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @await Html.PartialAsync("_PaginationUI", new { Page = Model.Filter.Page, TotalPages = Model.TotalPages, TotalCount = Model.TotalCount, ItemName = "việc làm" })
        }
    </div>
</section>

@section Scripts {
    <!-- Toast container -->
    <div id="bookmark-toast" class="fixed bottom-6 right-6 z-50 hidden">
        <div class="bg-white border border-[#D6DDEB] shadow-xl rounded-2xl px-5 py-4 flex items-center gap-3 min-w-[280px]">
            <div id="bookmark-toast-icon" class="w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
                </svg>
            </div>
            <p id="bookmark-toast-msg" class="text-[14px] font-medium text-dark"></p>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // ── Sidebar filter collapse/expand ────────────────────────────────
            document.querySelectorAll('.filter-header').forEach(header => {
                header.addEventListener('click', () => {
                    const content = header.nextElementSibling;
                    const icon    = header.querySelector('.filter-icon');
                    const isOpen  = content.style.maxHeight !== '0px' && content.style.maxHeight !== '';
                    if (isOpen) {
                        content.style.maxHeight = '0px';
                        content.style.opacity   = '0';
                        icon.classList.add('rotate-180');
                    } else {
                        content.style.maxHeight = content.scrollHeight + 'px';
                        content.style.opacity   = '1';
                        icon.classList.remove('rotate-180');
                    }
                });
            });
            document.querySelectorAll('.filter-content').forEach(content => {
                content.style.maxHeight = content.scrollHeight + 'px';
                content.style.opacity   = '1';
            });

            // ── Quick-filter panel toggle ─────────────────────────────────────
            window.togglePanel = function(id) {
                const panels = ['tech-panel', 'filter-city-panel', 'filter-company-panel'];
                panels.forEach(pid => {
                    const el = document.getElementById(pid);
                    if (pid === id) { el.classList.toggle('hidden'); }
                    else { el.classList.add('hidden'); }
                });
            };
            document.addEventListener('click', function(e) {
                if (!e.target.closest('.quick-filter-wrapper')) {
                    document.querySelectorAll('[id$="-panel"]').forEach(p => p.classList.add('hidden'));
                }
            });

            // ── Bookmark toggle ───────────────────────────────────────────────
            function showToast(message, type) {
                const toast   = document.getElementById('bookmark-toast');
                const msg     = document.getElementById('bookmark-toast-msg');
                const iconBox = document.getElementById('bookmark-toast-icon');
                msg.textContent = message;
                if (type === 'success') {
                    iconBox.className = 'w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0 bg-primary/10 text-primary';
                } else {
                    iconBox.className = 'w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0 bg-red-50 text-red-500';
                }
                toast.classList.remove('hidden');
                setTimeout(() => toast.classList.add('hidden'), 2500);
            }

            document.querySelectorAll('.bookmark-btn').forEach(btn => {
                btn.addEventListener('click', async function(e) {
                    e.preventDefault();
                    e.stopPropagation();

                    // Kiểm tra trạng thái đăng nhập từ wrapper cha
                    const wrapper = btn.closest('[data-is-authenticated]');
                    const isAuth  = wrapper && wrapper.dataset.isAuthenticated === 'true';

                    if (!isAuth) {
                        showToast('Vui lòng đăng nhập để lưu việc làm', 'error');
                        setTimeout(() => { window.location.href = '/Auth/Login'; }, 2000);
                        return;
                    }

                    const jobId = btn.dataset.jobId;
                    try {
                        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                        const res   = await fetch(`/candidate/bookmarks/toggle?jobId=${jobId}`, {
                            method: 'POST',
                            headers: { 'RequestVerificationToken': token }
                        });
                        if (!res.ok) throw new Error();
                        const data = await res.json();

                        const svg = btn.querySelector('svg');
                        if (data.isBookmarked) {
                            btn.dataset.bookmarked = 'true';
                            btn.title = 'Bỏ lưu việc làm';
                            btn.className = btn.className
                                .replace('bg-gray-50 text-gray-400 hover:text-primary hover:bg-primary/10 border-gray-100', '')
                                + ' bg-primary/10 text-primary border-primary/30';
                            svg.setAttribute('fill', 'currentColor');
                            showToast('Đã lưu việc làm thành công!', 'success');
                        } else {
                            btn.dataset.bookmarked = 'false';
                            btn.title = 'Lưu việc làm';
                            btn.className = btn.className
                                .replace('bg-primary/10 text-primary border-primary/30', '')
                                + ' bg-gray-50 text-gray-400 hover:text-primary hover:bg-primary/10 border-gray-100';
                            svg.setAttribute('fill', 'none');
                            showToast('Đã bỏ lưu việc làm', 'success');
                        }
                    } catch {
                        showToast('Có lỗi xảy ra, vui lòng thử lại', 'error');
                    }
                });
        });

        // Dual Range Salary Slider Logic with Revert Validation
        const minSlider = document.getElementById('min-salary-slider');
        const maxSlider = document.getElementById('max-salary-slider');
        const displayMin = document.getElementById('display-min-salary');
        const displayMax = document.getElementById('display-max-salary');
        const hiddenMin = document.getElementById('hidden-min-salary');
        const hiddenMax = document.getElementById('hidden-max-salary');
        const sliderTrack = document.getElementById('slider-track');
        const maxLimit = 100000000;

        let lastValidMinVal = parseInt(minSlider?.value) || 0;
        let lastValidMaxVal = parseInt(maxSlider?.value) || maxLimit;

        function formatThousand(val) {
            if (val === null || val === undefined || val === '') return '';
            var digits = String(val).replace(/\D/g, '');
            if (!digits) return '';
            return digits.replace(/\B(?=(\d{3})+(?!\d))/g, '.');
        }

        function parseMoney(val) {
            if (!val) return 0;
            var digits = String(val).replace(/\D/g, '');
            return digits ? parseInt(digits, 10) : 0;
        }

        function updateSliderTrack(minVal, maxVal) {
            const leftPercent = (minVal / maxLimit) * 100;
            const rightPercent = 100 - (maxVal / maxLimit) * 100;
            if (sliderTrack) {
                sliderTrack.style.left = leftPercent + '%';
                sliderTrack.style.right = rightPercent + '%';
            }
        }

        function syncFromSliders(eventSource) {
            if (!minSlider || !maxSlider) return;
            let minVal = parseInt(minSlider.value) || 0;
            let maxVal = parseInt(maxSlider.value) || maxLimit;

            if (minVal > maxVal) {
                if (eventSource === 'min') {
                    minVal = maxVal;
                    minSlider.value = minVal;
                } else {
                    maxVal = minVal;
                    maxSlider.value = maxVal;
                }
            }

            lastValidMinVal = minVal;
            lastValidMaxVal = maxVal;

            if (eventSource === 'min' || minVal > maxLimit / 2) {
                minSlider.style.zIndex = '30';
                maxSlider.style.zIndex = '20';
            } else {
                minSlider.style.zIndex = '20';
                maxSlider.style.zIndex = '30';
            }

            if (displayMin) displayMin.value = minVal > 0 ? formatThousand(minVal) : '';
            if (displayMax) displayMax.value = maxVal < maxLimit ? formatThousand(maxVal) : '';
            if (hiddenMin) hiddenMin.value = minVal > 0 ? minVal : '';
            if (hiddenMax) hiddenMax.value = maxVal < maxLimit ? maxVal : '';

            updateSliderTrack(minVal, maxVal);
        }

        function validateAndSyncMinInput() {
            let inputMinVal = parseMoney(displayMin.value);
            let currentMaxVal = parseMoney(displayMax.value) || maxLimit;

            if (inputMinVal > currentMaxVal) {
                if (typeof showToast === 'function') {
                    showToast('Lương tối thiểu không được lớn hơn lương tối đa!', 'error');
                }
                displayMin.value = lastValidMinVal > 0 ? formatThousand(lastValidMinVal) : '';
                return false;
            }

            if (inputMinVal < 0) inputMinVal = 0;
            if (inputMinVal > maxLimit) inputMinVal = maxLimit;

            lastValidMinVal = inputMinVal;
            minSlider.value = inputMinVal;
            if (hiddenMin) hiddenMin.value = inputMinVal > 0 ? inputMinVal : '';

            updateSliderTrack(inputMinVal, currentMaxVal);
            return true;
        }

        function validateAndSyncMaxInput() {
            let inputMaxVal = parseMoney(displayMax.value) || maxLimit;
            let currentMinVal = parseMoney(displayMin.value) || 0;

            if (inputMaxVal < currentMinVal && displayMax.value.trim() !== '') {
                if (typeof showToast === 'function') {
                    showToast('Lương tối đa không được nhỏ hơn lương tối thiểu!', 'error');
                }
                displayMax.value = lastValidMaxVal < maxLimit ? formatThousand(lastValidMaxVal) : '';
                return false;
            }

            if (inputMaxVal <= 0 || inputMaxVal > maxLimit) inputMaxVal = maxLimit;

            lastValidMaxVal = inputMaxVal;
            maxSlider.value = inputMaxVal;
            if (hiddenMax) hiddenMax.value = inputMaxVal < maxLimit ? inputMaxVal : '';

            updateSliderTrack(currentMinVal, inputMaxVal);
            return true;
        }

        if (minSlider && maxSlider) {
            minSlider.addEventListener('input', () => syncFromSliders('min'));
            maxSlider.addEventListener('input', () => syncFromSliders('max'));

            minSlider.addEventListener('mousedown', () => { minSlider.style.zIndex = '40'; maxSlider.style.zIndex = '20'; });
            maxSlider.addEventListener('mousedown', () => { maxSlider.style.zIndex = '40'; minSlider.style.zIndex = '20'; });
            minSlider.addEventListener('touchstart', () => { minSlider.style.zIndex = '40'; maxSlider.style.zIndex = '20'; });
            maxSlider.addEventListener('touchstart', () => { maxSlider.style.zIndex = '40'; minSlider.style.zIndex = '20'; });

            if (displayMin) {
                displayMin.addEventListener('input', function() {
                    this.value = formatThousand(this.value);
                });
                displayMin.addEventListener('change', validateAndSyncMinInput);
                displayMin.addEventListener('blur', validateAndSyncMinInput);
            }
            if (displayMax) {
                displayMax.addEventListener('input', function() {
                    this.value = formatThousand(this.value);
                });
                displayMax.addEventListener('change', validateAndSyncMaxInput);
                displayMax.addEventListener('blur', validateAndSyncMaxInput);
            }

            // Initial sync
            syncFromSliders('init');
        }

        const filterForm = document.getElementById('filter-form');
        if (filterForm) {
            filterForm.addEventListener('submit', function(e) {
                const isMinValid = validateAndSyncMinInput();
                const isMaxValid = validateAndSyncMaxInput();

                if (!isMinValid || !isMaxValid) {
                    e.preventDefault();
                    e.stopPropagation();
                    return false;
                }
            });
        }

        window.setSalaryPreset = function(minVal, maxVal) {
            if (minSlider) minSlider.value = minVal;
            if (maxSlider) maxSlider.value = maxVal;
            syncFromSliders('min');
        };
        });
    </script>

    <style>
        .range-slider-input {
            pointer-events: none;
            height: 0;
            outline: none;
        }
        .range-slider-input::-webkit-slider-thumb {
            pointer-events: auto;
            -webkit-appearance: none;
            appearance: none;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: #4640DE;
            border: 2px solid #ffffff;
            box-shadow: 0 2px 6px rgba(0,0,0,0.3);
            cursor: grab;
            position: relative;
            z-index: 30;
        }
        .range-slider-input::-webkit-slider-thumb:active {
            cursor: grabbing;
            transform: scale(1.15);
        }
        .range-slider-input::-moz-range-thumb {
            pointer-events: auto;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: #4640DE;
            border: 2px solid #ffffff;
            box-shadow: 0 2px 6px rgba(0,0,0,0.3);
            cursor: grab;
            position: relative;
            z-index: 30;
        }
        .range-slider-input::-moz-range-thumb:active {
            cursor: grabbing;
            transform: scale(1.15);
        }
    </style>
}
